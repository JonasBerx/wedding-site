{
  "name": "wedding-backend",
  "version": "1.0.0",
  "main": "src/server.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"node src/server.js\"",
    "build": "vite build",
    "start": "node src/server.js",
    "test": "jest",
    "lint": "eslint .",
    "test:client": "vitest run",
    "format": "prettier --write ."
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["<rootDir>/tests/**/*.test.js"]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@vitejs/plugin-react": "^6.0.1",
    "basic-auth": "^2.0.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "ffmpeg-static": "^5.3.0",
    "file-type": "^16.5.4",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0",
    "sharp": "^0.34.5",
    "vite": "^8.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "supertest": "^6.3.4",
    "vitest": "^4.1.7"
  }
}
